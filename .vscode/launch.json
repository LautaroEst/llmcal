            "program": "${workspaceFolder}/scripts/generate_train_shots.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--dataset_name", "glue/sst2",
                "--num_shots", "15",
                "--seed", "84283",
            ]
        },
        {
            "name": "run_dataset_on_model.py",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/run_dataset_on_model.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--model_name", "gpt2",
                "--dataset_name", "tony_zhao/sst2",
                "--templates_path", "${workspaceFolder}/results/templates",
                "--splits", "test",
                "--num_samples", "None",
                "--output_dir", "${workspaceFolder}/results",
                "--save_embeddings",
                "--batch_size", "32",
                "--num_seeds", "1",
                "--random_state", "84283",
            ]
        }
    ]
